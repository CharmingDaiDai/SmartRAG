# ------------------------------------------------
# Dependencies (依赖)
# ------------------------------------------------
/node_modules
/.pnp
.pnp.js

# ------------------------------------------------
# Build Output (构建产物)
# ------------------------------------------------
/build
/dist
/out
# Next.js 特有
/.next/
# Parcel 特有
.cache/
# Storybook 静态构建产物
/storybook-static

# ------------------------------------------------
# Environment Variables (环境变量 - 核心安全！)
# ------------------------------------------------
# 只保留 .env.example
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ------------------------------------------------
# Logs (日志)
# ------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------
# IDE & Editor Configs (编辑器配置)
# ------------------------------------------------
# Mac 系统文件
.DS_Store

# Windows 系统文件
Thumbs.db
ehthumbs.db
Desktop.ini

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# JetBrains (WebStorm, IntelliJ IDEA)
.idea/

# Sublime Text
*.sublime-project
*.sublime-workspace

# ------------------------------------------------
# Testing & Quality (测试与代码质量)
# ------------------------------------------------
/coverage
# Jest snapshot (有时需要提交，视情况而定，通常不忽略)
# __snapshots__

# ESLint 缓存 (加速 Lint 检查，不需要提交)
.eslintcache

# Prettier 缓存
.prettiercache

# ------------------------------------------------
# TypeScript
# ------------------------------------------------
# 增量编译信息，不需要提交
*.tsbuildinfo

# ------------------------------------------------
# Debugging / Misc
# ------------------------------------------------
# 临时的 debug 文件
debug.log

# Temporary folders generated by OS or tools
.tmp/
.temp/