# ==========================================
# SmartRAG 环境配置模板 (.env-example)
# 请复制本文件重命名为 .env，并修改其中的密钥和配置
# ==========================================

# ============ 基础与环境配置 ============
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
LOGGING_LEVEL=INFO
# Docker 容器数据挂载根目录
DOCKER_VOLUME_DIRECTORY=./data

# ============ 数据库配置 (MySQL) ============
# 这四个变量不仅用于后端连接，还用于首次启动 Docker MySQL 时的自动初始化
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MYSQL_DATABASE=smartrag_db
MYSQL_USER=smartrag_user
MYSQL_PASSWORD=SmartRAG_user_2026!
# 若你在本地 IDE 直接运行后端，请取消注释以下两行并设置为 127.0.0.1 和 13306
# DB_HOST=127.0.0.1
# DB_PORT=13306

# ============ 对象存储 (MinIO) ============
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ============ 安全与认证 ============
# JWT 密钥 (请务必修改为一个大于32位的复杂字符串)
# 请生成一个强随机密钥用于生产环境
# 可用命令生成：openssl rand -hex 32
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_ISSUER_URI=http://localhost:8080
# GitHub OAuth (不用可留空)
GITHUB_CLIENT_ID=Ov23likkGTPTqjQuzHfV
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/callback/github


# ==========================================
#              AI 模型全局配置
# ==========================================
# 决定系统默认使用哪个供应商的哪一个模型
# 格式：provider_name@model_name
ACTIVE_LLM=zhipuai@glm-4-flash
ACTIVE_EMBEDDING=modelscope@Qwen/Qwen3-Embedding-4B

# ============ 1. 智谱 GLM 配置 ============
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn
GLM_MODEL_NAME=glm-4-flash

# ============ 2. OpenAI 配置 (支持兼容的第三方代理) ============
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4

# ============ 3. Google Gemini 配置 ============
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL_NAME=gemini-pro

# ============ 4. 阿里 Qwen 向量模型配置 ============
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_EMBEDDING_MODEL=text-embedding-v4

# ============ 5. 魔搭 ModelScope 向量模型配置 ============
MODELSCOPE_API_KEY=your_modelscope_api_key_here
MODELSCOPE_BASE_URL=https://ms-YOUR_API_URL
MODELSCOPE_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B

# ============ 6. Xinference 本地部署向量模型 ============
XINFERENCE_API_KEY=notnull
XINFERENCE_BASE_URL=http://127.0.0.1:9997/v1/
XINFERENCE_EMBEDDING_MODEL=bge-m3