# SmartDoc 环境变量配置模板
# 复制此文件为 .env 并根据你的环境修改值
# 此文件可提交到 Git；.env 文件包含真实密钥，不可提交

# ============ Docker Volume ============
# 数据持久化路径，默认映射到项目目录下的 data 文件夹
DOCKER_VOLUME_DIRECTORY=./data

# ============ MySQL Service Configuration ============
# 以下四个变量用于初始化 Docker Compose 中的 MySQL 容器
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MYSQL_DATABASE=smartrag_db
MYSQL_USER=smartrag_user
MYSQL_PASSWORD=your_mysql_user_password_here

# ============ Database Configuration ============
# 在 Docker Compose 中，使用服务名 (mysql)；如果是外部数据库，使用 IP 或域名
DB_HOST=mysql
DB_PORT=3306
DB_NAME=smartrag_db
DB_USERNAME=smartrag_user
# 必须与上方 MYSQL_PASSWORD 保持一致
DB_PASSWORD=your_mysql_user_password_here

# ============ JWT Configuration ============
# 请生成一个强随机密钥用于生产环境
# 可用命令生成：openssl rand -hex 32
JWT_SECRET=generate-a-strong-random-key-here-minimum-32-characters
JWT_ISSUER_URI=http://localhost:8080

# ============ GitHub OAuth Configuration (Optional) ============
# 如果不使用 GitHub OAuth，可以留空或保持占位值
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://your-domain.com:8080/api/auth/callback/github

# ============ AI Model Configuration ============
# 至少配置一个 AI 模型 (GLM, OpenAI, Gemini 等)

# Zhipu GLM API
GLM_API_KEY=your_glm_api_key_here

# OpenAI API (Optional)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API (Optional)
GEMINI_API_KEY=your_gemini_api_key_here

# ============ Embedding Model Configuration ============
# 嵌入模型用于文档向量化，可以是本地服务或 API 服务
# Xinference 本地部署示例（推荐）：
EMBEDDING_API_KEY=notnull
EMBEDDING_BASE_URL=http://embedding-service:9997/v1/
EMBEDDING_MODEL_NAME=bge-m3

# ============ Milvus Vector Database Configuration ============
# 如果使用 Docker Compose，服务名是 milvus；如果是外部 Milvus，填入 IP/域名
MILVUS_HOST=milvus
MILVUS_PORT=19530

# ============ MinIO Object Storage Configuration ============
# 如果使用 Docker Compose，服务名是 minio；如果是外部 MinIO，填入完整地址
MINIO_ENDPOINT=http://minio:9000
# 需与 Docker Compose MySQL 服务的 MINIO_ACCESS_KEY / MINIO_SECRET_KEY 一致
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# ============ Spring Boot Server Configuration (Optional) ============
# 如果需要修改服务器端口，可以取消注释并修改
# SERVER_PORT=8080

# ============ Logging Configuration (Optional) ============
# 日志级别: TRACE, DEBUG, INFO, WARN, ERROR
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_COM_SMARTDOC=DEBUG
