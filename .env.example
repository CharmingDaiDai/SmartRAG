# smartDoc Production/Runtime Environment Configuration
# 用于 docker-compose.runtime.yml 生产环境部署
# 复制此文件为 .env 并根据你的生产环境修改值

# ============ Database Configuration ============
# 在 Docker Compose 中，使用服务名 (mysql)；如果是外部数据库，使用 IP 或域名
DB_HOST=mysql
DB_PORT=3306
DB_NAME=smart_doc
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# ============ JWT Configuration ============
# 请生成一个强随机密钥用于生产环境
JWT_SECRET=generate-a-strong-random-key-here-minimum-32-characters
JWT_ISSUER_URI=http://localhost:8080

# ============ GitHub OAuth Configuration (Optional) ============
# 如果不使用 GitHub OAuth，可以留空
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://your-domain.com:8080/api/auth/callback/github

# ============ AI Model Configuration ============
# 至少配置一个 AI 模型 (GLM, OpenAI, Gemini 等)

# Zhipu GLM API
GLM_API_KEY=your_glm_api_key_here

# OpenAI API (Optional)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API (Optional)
GEMINI_API_KEY=your_gemini_api_key_here

# ============ Embedding Model Configuration ============
# 嵌入模型用于文档向量化，可以是本地服务或 API 服务
EMBEDDING_API_KEY=notnull
EMBEDDING_BASE_URL=http://embedding-service:9997/v1/
EMBEDDING_MODEL_NAME=bge-m3

# ============ Milvus Vector Database Configuration ============
# 如果使用 Docker Compose，服务名是 milvus-standalone；否则填入 Milvus 服务器 IP/域名
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# ============ MinIO Object Storage Configuration ============
# 如果使用 Docker Compose，服务名是 minio；否则填入 MinIO 服务器地址
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# ============ Spring Boot Server Configuration (Optional) ============
# 如果需要修改服务器端口，可以取消注释并修改
# SERVER_PORT=8080

# ============ Logging Configuration (Optional) ============
# 日志级别: TRACE, DEBUG, INFO, WARN, ERROR
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_COM_SMARTDOC=DEBUG

